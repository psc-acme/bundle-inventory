{
    "name": "psc-acme/bundle-inventory",
    "description": "Package bundle-inventory for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\BundleInventory\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "aws/aws-sdk-php": "^3.332",
        "psr/event-dispatcher": "^1.0",
        "symfony/mailer": "^7.0",
        "psc-acme/toolkit-cart": "^1.0",
        "psc-acme/connector-catalog": "^1.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.0",
        "infection/infection": "^0.27",
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}